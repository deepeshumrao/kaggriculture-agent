# Copy this file to ".env" and fill in values.
# Only required if you enable the LLM (Gemini) policy. The default heuristic
# strategy runs with NO key and NO cost.

# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Model to use (free-tier friendly). Flash is cheapest/fastest.
KAGGRICULTURE_MODEL=gemini-2.5-flash

# Set to "llm" to use the Gemini policy, or "heuristic" (default, free).
KAGGRICULTURE_POLICY=heuristic
